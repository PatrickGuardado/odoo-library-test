<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">
        <record id="module_category_library" model="ir.module.category">
            <field name="name">Biblioteca</field>
            <field name="sequence">10</field>
        </record>

        <record id="privilege_library_access" model="res.groups.privilege">
            <field name="name">Nivel de Acceso</field>
            <field name="category_id" ref="module_category_library"/>
        </record>

        <record id="group_library_public" model="res.groups">
            <field name="name">Usuario Público</field>
            <field name="privilege_id" ref="privilege_library_access"/>
        </record>

        <record id="group_library_librarian" model="res.groups">
            <field name="name">Bibliotecario</field>
            <field name="privilege_id" ref="privilege_library_access"/>
            <field name="implied_ids" eval="[(4, ref('group_library_public'))]"/>
        </record>

        <record id="rule_public_available_books" model="ir.rule">
            <field name="name">Público: Solo libros disponibles</field>
            <field name="model_id" ref="model_library_book"/>
            <field name="groups" eval="[(4, ref('group_library_public'))]"/>
            <field name="domain_force">[('state', '=', 'available')]</field>
        </record>

        <record id="rule_librarian_all_books" model="ir.rule">
            <field name="name">Bibliotecario: Todos los libros</field>
            <field name="model_id" ref="model_library_book"/>
            <field name="groups" eval="[(4, ref('group_library_librarian'))]"/>
            <field name="domain_force">[(1, '=', 1)]</field>
        </record>
    </data>
</odoo>