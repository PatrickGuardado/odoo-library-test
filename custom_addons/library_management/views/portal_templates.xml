<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="portal_my_home_library" name="Mostrar Préstamos" inherit_id="portal.portal_my_home" priority="20">
        <xpath expr="//div[hasclass('o_portal_docs')]" position="inside">
            <t t-call="portal.portal_docs_entry">
                <t t-set="title">Mis Préstamos</t>
                <t t-set="url" t-value="'/my/loans'"/>
                <t t-set="count" t-value="request.env['library.loan'].sudo().search_count([('partner_id', '=', request.env.user.partner_id.id)])"/>
                <t t-set="show_zero" t-value="True"/>
                <t t-set="bg_color" t-value="'bg-primary'"/>
            </t>
        </xpath>
    </template>

    <template id="portal_my_loans" name="Mis Préstamos">
        <t t-call="portal.portal_layout">
            <t t-set="breadcrumbs_searchbar" t-value="True"/>
            <t t-call="portal.portal_searchbar">
                <t t-set="title">Mis Préstamos</t>
            </t>
            
            <t t-if="not loans">
                <p class="alert alert-warning mt-4">Actualmente no tienes préstamos registrados.</p>
            </t>
            
            <t t-if="loans" t-call="portal.portal_table">
                <thead>
                    <tr class="active">
                        <th>Libro</th>
                        <th>Fecha de Préstamo</th>
                        <th>Estado</th>
                        <th>Acción</th>
                    </tr>
                </thead>
                <tbody>
                    <t t-foreach="loans" t-as="loan">
                        <tr>
                            <td><span t-field="loan.book_id.name"/></td>
                            <td><span t-field="loan.loan_date"/></td>
                            <td>
                                <span t-if="loan.state == 'active'" class="badge rounded-pill text-bg-info">Activo</span>
                                <span t-if="loan.state == 'overdue'" class="badge rounded-pill text-bg-danger">Vencido</span>
                                <span t-if="loan.state == 'returned'" class="badge rounded-pill text-bg-success">Devuelto</span>
                            </td>
                            <td>
                                <a t-if="loan.state == 'active'" t-attf-href="/my/loans/renew/#{loan.id}" class="btn btn-sm btn-primary">Renovar</a>
                            </td>
                        </tr>
                    </t>
                </tbody>
            </t>
        </t>
    </template>
</odoo>